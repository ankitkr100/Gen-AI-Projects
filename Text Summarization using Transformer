from transformers import BartForConditionalGeneration, BartTokenizer

MODEL_NAME = "facebook/bart-large-cnn"

tokenizer = BartTokenizer.from_pretrained(MODEL_NAME)
model = BartForConditionalGeneration.from_pretrained(MODEL_NAME)

def summarize_text(text: str, max_length: int = 130, min_length: int = 30) -> str:
    """Summarize input text using BART-large-CNN."""
    inputs = tokenizer(text, return_tensors="pt", max_length=1024, truncation=True)
    
    summary_ids = model.generate(
        inputs["input_ids"],
        max_length=max_length,
        min_length=min_length,
        length_penalty=2.0,
        num_beams=4,
        early_stopping=True
    )
    
    return tokenizer.decode(summary_ids[0], skip_special_tokens=True)


if __name__ == "__main__":
    text = """Cristiano Ronaldo dos Santos Aveiro (born 5 February 1985), nicknamed CR7, is a Portuguese 
    professional footballer who plays as a forward for and captains both Saudi Pro League club Al-Nassr 
    and the Portugal national team. Widely regarded as one of the greatest players in history, he has won 
    numerous individual accolades throughout his career, including five Ballon d'Ors, a record three UEFA 
    Men's Player of the Year Awards, and four European Golden Shoes. He was also named the world's best 
    player five times by FIFA."""
    
    print(summarize_text(text))
